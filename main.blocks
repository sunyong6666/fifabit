<xml xmlns="https://developers.google.com/blockly/xml"><variables><variable id="{A:D:EWuu|+rU=:[MLFn">i2cAddress</variable></variables><block type="pxt-on-start" id="h:T:7+^q2kHs!S)L__+s" x="0" y="0"><statement name="HANDLER"><block type="variables_set" id="G-r0Ev,qkbm`2Qla(YJ)"><field name="VAR" id="{A:D:EWuu|+rU=:[MLFn">i2cAddress</field><comment pinned="false" h="80" w="160">I2C设备地址</comment><value name="VALUE"><shadow type="math_number" id="#N4-8U%{aM4J)6onYE@+"><field name="NUM">16</field></shadow></value><next><block type="typescript_statement" id="]g(B:%3mn#0C2*U@N.Cr"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType {" line1="    //% block=&quot;前进&quot;" line2="    type1 = 1," line3="    //% block=&quot;后退&quot;" line4="    type2 = 2," line5="    //% block=&quot;左转&quot;" line6="    type3 = 3," line7="    //% block=&quot;右转&quot;" line8="    type4 = 4" line9="}" numlines="10"></mutation><next><block type="typescript_statement" id="b7jGJXKluQ.PYK!N-|H("><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType1 {" line1="    //% block=&quot;前进&quot;" line2="    type1 = 5," line3="    //% block=&quot;后退&quot;" line4="    type2 = 6" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="FwL~dy)WSv=PS$XlGlhu"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motorID {" line1="    //% block=&quot;0&quot;" line2="    motor0 = 0x50," line3="    //% block=&quot;1&quot;" line4="    motor1 = 0x6E" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="Ijiatiq?ELRj!pD]:_)2"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motorDirection {" line1="    //% block=&quot;clockwise&quot;" line2="    clockwise = 1,  " line3="    //% block=&quot;counterclockwise&quot;" line4="    counterclockwise = 2   " line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="#[]@B!iQ6[o*%ZJ`SEUy"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace FIFAbit {" line1="    //% blockId=motionSpeed" line2="    //% block=&quot;%mtype with speed %mspeed&quot;" line3="    //% group=&quot;Motion&quot; weight=3" line4="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line5="    export function motionSpeed(mtype: motionType, mspeed: number): void {" line6="        const spAddr = 0x8C + 0x02;//设置速度" line7="        let spBuff = pins.createBuffer(5);" line8="        spBuff.setNumber(NumberFormat.UInt8BE, 0, spAddr);" line9="        spBuff.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line10="        spBuff.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line11="        spBuff.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line12="        spBuff.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line13="        pins.i2cWriteBuffer(i2cAddress, spBuff);" line14="        const regAddr = 0x8C + 0x00;//执行" line15="        let cmdBuff = pins.createBuffer(2);" line16="        cmdBuff.setNumber(NumberFormat.UInt8BE, 0, regAddr);" line17="        cmdBuff.setNumber(NumberFormat.UInt8BE, 1, mtype);" line18="        pins.i2cWriteBuffer(i2cAddress, cmdBuff);" line19="    }" line20="    //% blockId=motionDistance" line21="    //% block=&quot;%mtype with speed %mspeed and distance %distance cm&quot;" line22="    //% group=&quot;Motion&quot; weight=2" line23="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line24="    //% distance.min=0 distance.max=1000 distance.defl=10" line25="    export function motionDistance(mtype: motionType1, mspeed: number, distance: number): void {" line26="        const spAddr2 = 0x8C + 0x02;//设置速度" line27="        let spBuff2 = pins.createBuffer(5);" line28="        spBuff2.setNumber(NumberFormat.UInt8BE, 0, spAddr2);" line29="        spBuff2.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line30="        spBuff2.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line31="        spBuff2.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line32="        spBuff2.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line33="        pins.i2cWriteBuffer(i2cAddress, spBuff2);" line34="        const disAddr = 0x8C + 0x05;//设置距离" line35="        let disBuff = pins.createBuffer(3);" line36="        disBuff.setNumber(NumberFormat.UInt8BE, 0, disAddr);" line37="        // disBuff.setNumber(NumberFormat.UInt8BE, 1, (distance &gt;&gt; 8) &amp; 0xFF);" line38="        // disBuff.setNumber(NumberFormat.UInt8BE, 2, distance &amp; 0xFF);" line39="        disBuff.setNumber(NumberFormat.UInt16BE, 1, distance);" line40="        pins.i2cWriteBuffer(i2cAddress, disBuff);" line41="        const regAddr2 = 0x8C + 0x00;//执行" line42="        let cmdBuff2 = pins.createBuffer(2);" line43="        cmdBuff2.setNumber(NumberFormat.UInt8BE, 0, regAddr2);" line44="        cmdBuff2.setNumber(NumberFormat.UInt8BE, 1, mtype);" line45="        pins.i2cWriteBuffer(i2cAddress, cmdBuff2);" line46="    }" line47="    //% blockId=motionStop" line48="    //% block=&quot;stop motion&quot;" line49="    //% group=&quot;Motion&quot; weight=1" line50="    export function motionStop(): void {" line51="        const regAddr3 = 0x8C + 0x00;//执行" line52="        let cmdBuff3 = pins.createBuffer(2);" line53="        cmdBuff3.setNumber(NumberFormat.UInt8BE, 0, regAddr3);" line54="        cmdBuff3.setNumber(NumberFormat.UInt8BE, 1, 0);" line55="        pins.i2cWriteBuffer(i2cAddress, cmdBuff3);" line56="    }" line57="    //#########################################################################" line58="    //##################################单电机#################################" line59="    //#########################################################################" line60="    //% blockId=motorGetSpeed" line61="    //% block=&quot;motor %mID speed&quot;" line62="    //% group=&quot;Motor&quot; weight=9" line63="    export function motorGetSpeed(mID: motorID): number {" line64="        // 发送指令" line65="        const cmdAddr = mID + 0x01;" line66="        let cmdBuff4 = pins.createBuffer(1);" line67="        cmdBuff4.setNumber(NumberFormat.UInt8BE, 0, cmdAddr);" line68="        pins.i2cWriteBuffer(i2cAddress, cmdBuff4);" line69="        return 0;" line70="    }" line71="" line72="    //% blockId=motorRunSpeed" line73="    //% block=&quot;motor %mID go %direction with speed %speed&quot;" line74="    //% group=&quot;Motor&quot; weight=8" line75="    //% speed.min=0 speed.max=100 speed.defl=50" line76="    export function motorRunSpeed(mID: motorID, direction: motorDirection, speed: number): void {" line77="        // 设置速度" line78="        const spAddr3 = mID + 0x04;" line79="        let spBuff3 = pins.createBuffer(3);" line80="        spBuff3.setNumber(NumberFormat.UInt8BE, 0, spAddr3);" line81="        spBuff3.setNumber(NumberFormat.UInt8BE, 1, (speed &gt;&gt; 8) &amp; 0xFF); " line82="        spBuff3.setNumber(NumberFormat.UInt8BE, 2, speed &amp; 0xFF); " line83="        pins.i2cWriteBuffer(i2cAddress, spBuff3);" line84="        // 发送运动指令" line85="        const cmdAddr2 = mID + 0x03;" line86="        let cmdBuff5 = pins.createBuffer(2);" line87="        cmdBuff5.setNumber(NumberFormat.UInt8BE, 0, cmdAddr2);" line88="        cmdBuff5.setNumber(NumberFormat.UInt8BE, 1, direction);" line89="        pins.i2cWriteBuffer(i2cAddress, cmdBuff5);" line90="    }" line91="" line92="    //% blockId=motorRunDistance" line93="    //% block=&quot;motor %mID move %distance cm %direction with speed %speed&quot;" line94="    //% group=&quot;Motor&quot; weight=7" line95="    //% speed.min=0 speed.max=100 speed.defl=50" line96="    //% distance.min=0 distance.max=1000 distance.defl=10" line97="    export function motorRunDistance(mID: motorID, distance:number, direction: motorDirection, speed: number): void {" line98="        // 设置速度" line99="        const spAddr4 = mID + 0x04;" line100="        let spBuff4 = pins.createBuffer(3);" line101="        spBuff4.setNumber(NumberFormat.UInt8BE, 0, spAddr4);" line102="        spBuff4.setNumber(NumberFormat.UInt8BE, 1, (speed &gt;&gt; 8) &amp; 0xFF);" line103="        spBuff4.setNumber(NumberFormat.UInt8BE, 2, speed &amp; 0xFF);" line104="        pins.i2cWriteBuffer(i2cAddress, spBuff4);" line105="        //设置距离" line106="        const disAddr2 = mID + 0x07;" line107="        let disBuff2 = pins.createBuffer(3);" line108="        disBuff2.setNumber(NumberFormat.UInt8BE, 0, disAddr2);" line109="        // disBuff.setNumber(NumberFormat.UInt8BE, 1, (distance &gt;&gt; 8) &amp; 0xFF);" line110="        // disBuff.setNumber(NumberFormat.UInt8BE, 2, distance &amp; 0xFF);" line111="        disBuff2.setNumber(NumberFormat.UInt16BE, 1, distance);" line112="        pins.i2cWriteBuffer(i2cAddress, disBuff2);" line113="        // 发送运动指令" line114="        const cmdAddr3 = mID + 0x03;" line115="        let cmdBuff6 = pins.createBuffer(2);" line116="        cmdBuff6.setNumber(NumberFormat.UInt8BE, 0, cmdAddr3);" line117="        cmdBuff6.setNumber(NumberFormat.UInt8BE, 1, direction+4);" line118="        pins.i2cWriteBuffer(i2cAddress, cmdBuff6);" line119="    }" line120="    " line121="}" numlines="122"></mutation></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>