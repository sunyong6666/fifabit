<xml xmlns="https://developers.google.com/blockly/xml"><variables><variable id="^o)u_XfPNPK{(#TP;R3C">i2cAddress</variable></variables><block type="pxt-on-start" id="?kD*9b-xmuUCHUXH5puo" x="20" y="20"><statement name="HANDLER"><block type="variables_set" id="Ep:3?c]1|jo3UVB@F5tg"><field name="VAR" id="^o)u_XfPNPK{(#TP;R3C">i2cAddress</field><comment pinned="false" h="80" w="160">I2C设备地址</comment><value name="VALUE"><shadow type="math_number" id="_QYbmi6A-i;Qt#@HR^Ng"><field name="NUM">9</field></shadow></value><next><block type="typescript_statement" id="OiIPFY-s+Y.DsI1|{0zq"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType {" line1="    //% block=&quot;forward&quot;" line2="    type1 = 1," line3="    //% block=&quot;backward&quot;" line4="    type2 = 2," line5="    //% block=&quot;left&quot;" line6="    type3 = 3," line7="    //% block=&quot;right&quot;" line8="    type4 = 4" line9="}" numlines="10"></mutation><next><block type="typescript_statement" id="it8Z`:L9Lb^HZ4i(Wir1"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType1 {" line1="    //% block=&quot;forward&quot;" line2="    type1 = 5," line3="    //% block=&quot;backward&quot;" line4="    type2 = 6" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="oQHI5%ciz%KI@uv$M|=i"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motorID {" line1="    //% block=&quot;0&quot;" line2="    motor0 = 0x50," line3="    //% block=&quot;1&quot;" line4="    motor1 = 0x6E" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="I;-)Sk.@`_A4aN,]0zyq"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motorDirection {" line1="    //% block=&quot;forward&quot;" line2="    clockwise = 1," line3="    //% block=&quot;reverse&quot;" line4="    counterclockwise = 2" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="IwvhZQ%V`|6fES=e(k|g"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum enRGB {" line1="    //% block=&quot;R&quot;" line2="    Red," line3="    //% block=&quot;G&quot;" line4="    Green," line5="    //% block=&quot;B&quot;" line6="    Blue," line7="}" numlines="8"></mutation><next><block type="typescript_statement" id="9$2Y=Pt^~3A^KBf^7}cF"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum Ultrasonic_pin {" line1="    //% block=&quot;(P13,P0)&quot;" line2="    u1 = 13," line3="    //% block=&quot;(P14,P1)&quot;" line4="    u3 = 114," line5="    //% block=&quot;(P9,P12)&quot;" line6="    u4 = 129," line7="    //% block=&quot;(P15,P2)&quot;" line8="    u5 = 215" line9="}" numlines="10"></mutation><next><block type="typescript_statement" id="_l%6SfE5eB`1~z#0p+h,"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum PingUnit {" line1="    //% block=&quot;centimeters&quot;" line2="    Centimeters," line3="    //% block=&quot;microseconds&quot;" line4="    MicroSeconds," line5="    //% block=&quot;inches&quot;" line6="    Inches" line7="}" numlines="8"></mutation><next><block type="typescript_statement" id="xT7(O#=p^HN@~^7/rn(y"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum Write_pin {" line1="    //% block=&quot;P0&quot;" line2="    w0 = 1," line3="    //% block=&quot;P16&quot;" line4="    w1 = 2," line5="    //% block=&quot;P1&quot;" line6="    w2 = 3," line7="    //% block=&quot;P12&quot;" line8="    w3 = 4," line9="    //% block=&quot;P2&quot;" line10="    w4 = 5," line11="    //% block=&quot;P8&quot;" line12="    w5 = 6" line13="}" numlines="14"></mutation><next><block type="typescript_statement" id="-wGVf#7z}.eG#`!pf={%"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum ServoPin {" line1="    //% block=&quot;P0&quot;" line2="    P0 = DigitalPin.P0," line3="    //% block=&quot;P1&quot;" line4="    P1 = DigitalPin.P1," line5="    //% block=&quot;P2&quot;" line6="    P2 = DigitalPin.P2," line7="    //% block=&quot;P8&quot;" line8="    P8 = DigitalPin.P8," line9="    //% block=&quot;P12&quot;" line10="    P12 = DigitalPin.P12," line11="    //% block=&quot;P13&quot;" line12="    P13 = DigitalPin.P13," line13="    //% block=&quot;P15&quot;" line14="    P15 = DigitalPin.P15," line15="    //% block=&quot;P16&quot;" line16="    P16 = DigitalPin.P16" line17="}" numlines="18"></mutation><next><block type="typescript_statement" id="Vuoj;@s^+%Z4lil@yMfj"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum RotationDirection {" line1="    //% block=&quot;clockwise&quot;" line2="    Clockwise = 1," line3="    //% block=&quot;counterclockwise&quot;" line4="    Counterclockwise = -1" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="_RV9L(@4thtli/Nu5fJk"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum Colors {" line1="    //% block=红" line2="    Red = 0xFF0000," line3="    //% block=橙" line4="    Orange = 0xFF7F00," line5="    //% block=黄" line6="    Yellow = 0xFFFF00," line7="    //% block=绿" line8="    Green = 0x00FF00," line9="    //% block=青" line10="    Cyan = 0x00FFFF," line11="    //% block=蓝" line12="    Blue = 0x0000FF," line13="    //% block=紫" line14="    Purple = 0x7F00FF," line15="    //% block=白" line16="    White = 0xFFFFFF," line17="    //% block=黑" line18="    Off = 0x000000" line19="}" numlines="20"></mutation><next><block type="typescript_statement" id="p9sEWh(hYmJHfP25!IK+"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum PotPin {" line1="    //% block=&quot;P0&quot;" line2="    P0 = AnalogPin.P0," line3="    //% block=&quot;P1&quot;" line4="    P1 = AnalogPin.P1," line5="    //% block=&quot;P2&quot;" line6="    P2 = AnalogPin.P2," line7="    //% block=&quot;P3&quot;" line8="    P3 = AnalogPin.P3," line9="    //% block=&quot;P4&quot;" line10="    P4 = AnalogPin.P4," line11="    //% block=&quot;P10&quot;" line12="    P10 = AnalogPin.P10" line13="}" numlines="14"></mutation><next><block type="typescript_statement" id="E%qfpY7fSW(02y;=5FR9"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum SensorSide {" line1="    //% block=&quot;左&quot;" line2="    Left = 1," line3="    //% block=&quot;中&quot;" line4="    Middle = 2," line5="    //% block=&quot;右&quot;" line6="    Right = 3" line7="}" numlines="8"></mutation><next><block type="typescript_statement" id="iYku1Fx#J|nja}@~@}Tb"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum rocket {" line1="    //% block=&quot;X&quot;" line2="    x = 1," line3="    //% block=&quot;Y&quot;" line4="    y = 2" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="IhqYrx+q.8~[#{!L;Z9I"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum rock {" line1="    //% block=&quot;up&quot;" line2="    orient1 = 2," line3="    //% block=&quot;down&quot;" line4="    orient2 = 1," line5="    //% block=&quot;left&quot;" line6="    orient3 = 4," line7="    //% block=&quot;right&quot;" line8="    orient4 = 3" line9="}" numlines="10"></mutation><next><block type="typescript_statement" id="XP^Gp_?eBmK/iFl(a#!o"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum DetectedColor {" line1="    //% block=&quot;红色&quot;" line2="    Red," line3="    //% block=&quot;黄色&quot;" line4="    Yellow," line5="    //% block=&quot;绿色&quot;" line6="    Green," line7="    //% block=&quot;蓝色&quot;" line8="    Blue," line9="    //% block=&quot;紫色&quot;" line10="    Purple," line11="    //% block=&quot;白色&quot;" line12="    White," line13="    //% block=&quot;黑色&quot;" line14="    Black" line15="}" numlines="16"></mutation><next><block type="typescript_statement" id="@QodztNxmuB4HUlLB(y4"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace FIFAbit {" line1="    //#########################################################################" line2="    //################################## 运动（双电机）#########################" line3="    //#########################################################################" line4="    //% blockId=motionSpeed" line5="    //% block=&quot;move %mtype at speed %mspeed&quot;" line6="    //% group=&quot;Motion&quot; weight=3" line7="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line8="    export function motionSpeed(mtype: motionType, mspeed: number): void {" line9="        const spAddr = 0x8C + 0x01;//设置速度" line10="        let spBuff = pins.createBuffer(5);" line11="        spBuff.setNumber(NumberFormat.UInt8BE, 0, spAddr);" line12="        spBuff.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line13="        spBuff.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line14="        spBuff.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line15="        spBuff.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line16="        pins.i2cWriteBuffer(i2cAddress, spBuff);" line17="        const regAddr = 0x8C + 0x00;//执行" line18="        let cmdBuff = pins.createBuffer(2);" line19="        cmdBuff.setNumber(NumberFormat.UInt8BE, 0, regAddr);" line20="        cmdBuff.setNumber(NumberFormat.UInt8BE, 1, mtype);" line21="        pins.i2cWriteBuffer(i2cAddress, cmdBuff);" line22="    }" line23="    //% blockId=motionDistance" line24="    //% block=&quot;move %mtype at speed %mspeed for %distance cm&quot;" line25="    //% group=&quot;Motion&quot; weight=2" line26="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line27="    //% distance.min=0 distance.max=1000 distance.defl=10" line28="    export function motionDistance(mtype: motionType1, mspeed: number, distance: number): void {" line29="        const spAddr2 = 0x8C + 0x01;//设置速度" line30="        let spBuff2 = pins.createBuffer(5);" line31="        spBuff2.setNumber(NumberFormat.UInt8BE, 0, spAddr2);" line32="        spBuff2.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line33="        spBuff2.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line34="        spBuff2.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line35="        spBuff2.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line36="        pins.i2cWriteBuffer(i2cAddress, spBuff2);" line37="        const disAddr = 0x8C + 0x02;//设置距离" line38="        let disBuff = pins.createBuffer(3);" line39="        disBuff.setNumber(NumberFormat.UInt8BE, 0, disAddr);" line40="        disBuff.setNumber(NumberFormat.UInt8BE, 1, (distance &gt;&gt; 8) &amp; 0xFF);" line41="        disBuff.setNumber(NumberFormat.UInt8BE, 2, distance &amp; 0xFF);" line42="        pins.i2cWriteBuffer(i2cAddress, disBuff);" line43="        const regAddr2 = 0x8C + 0x00;//执行" line44="        let cmdBuff2 = pins.createBuffer(2);" line45="        cmdBuff2.setNumber(NumberFormat.UInt8BE, 0, regAddr2);" line46="        cmdBuff2.setNumber(NumberFormat.UInt8BE, 1, mtype);" line47="        pins.i2cWriteBuffer(i2cAddress, cmdBuff2);" line48="    }" line49="    //% blockId=motionStop" line50="    //% block=&quot;stop motion&quot;" line51="    //% group=&quot;Motion&quot; weight=1" line52="    export function motionStop(): void {" line53="        const regAddr3 = 0x8C + 0x00;//执行" line54="        let cmdBuff3 = pins.createBuffer(2);" line55="        cmdBuff3.setNumber(NumberFormat.UInt8BE, 0, regAddr3);" line56="        cmdBuff3.setNumber(NumberFormat.UInt8BE, 1, 0);" line57="        pins.i2cWriteBuffer(i2cAddress, cmdBuff3);" line58="    }" line59="    //#########################################################################" line60="    //##################################单电机#################################" line61="    //#########################################################################" line62="    //% blockId=motorGetSpeed" line63="    //% block=&quot;get motor %mID speed&quot;" line64="    //% group=&quot;Motor&quot; weight=9" line65="    export function motorGetSpeed(mID: motorID): number {" line66="        // 发送指令" line67="        const cmdAddr = mID + 0x01;" line68="        let cmdBuff4 = pins.createBuffer(1);" line69="        cmdBuff4.setNumber(NumberFormat.UInt8BE, 0, cmdAddr);" line70="        pins.i2cWriteBuffer(i2cAddress, cmdBuff4);" line71="        // 拼接 2 字节为 16 位整数" line72="        // let readBuff = pins.createBuffer(2);" line73="        // readBuff = pins.i2cReadBuffer(i2cAddress, 2);" line74="        // let highByte = readBuff.getNumber(NumberFormat.UInt8BE, 0);" line75="        // let lowByte = readBuff.getNumber(NumberFormat.UInt8BE, 1);" line76="        // let speed = ((highByte &amp; 0xFF) &lt;&lt; 8) | (lowByte &amp; 0xFF);" line77="" line78="        // 读取2字节数据" line79="        let readBuff = pins.createBuffer(2);" line80="        readBuff = pins.i2cReadBuffer(i2cAddress, 2);" line81="        // 将2个字节作为有符号16位整数解析" line82="        let speed = readBuff.getNumber(NumberFormat.Int16BE, 0);" line83="        return speed; " line84="    }" line85="    //% blockId=motorSetSpeed" line86="    //% block=&quot;set motor %mID speed to %speed&quot;" line87="    //% group=&quot;Motor&quot; weight=8" line88="    //% speed.min=0 speed.max=100 speed.defl=50" line89="    export function motorSetSpeed(mID: motorID, speed: number): void {" line90="        // 设置速度" line91="        const spAddr3 = mID + 0x04;" line92="        let spBuff3 = pins.createBuffer(3);" line93="        spBuff3.setNumber(NumberFormat.UInt8BE, 0, spAddr3);" line94="        spBuff3.setNumber(NumberFormat.UInt8BE, 1, (speed &gt;&gt; 8) &amp; 0xFF);" line95="        spBuff3.setNumber(NumberFormat.UInt8BE, 2, speed &amp; 0xFF);" line96="        pins.i2cWriteBuffer(i2cAddress, spBuff3);" line97="    }" line98="    //% blockId=motorRun" line99="    //% block=&quot;run motor %mID %direction&quot;" line100="    //% group=&quot;Motor&quot; weight=7" line101="    export function motorRun(mID: motorID, direction: motorDirection): void {" line102="        // 发送运动指令" line103="        const cmdAddr2 = mID + 0x03;" line104="        let cmdBuff5 = pins.createBuffer(2);" line105="        cmdBuff5.setNumber(NumberFormat.UInt8BE, 0, cmdAddr2);" line106="        cmdBuff5.setNumber(NumberFormat.UInt8BE, 1, direction);" line107="        pins.i2cWriteBuffer(i2cAddress, cmdBuff5);" line108="    }" line109="    //% blockId=motorRunDistance" line110="    //% block=&quot;run motor %mID  %direction for %distance cm&quot;" line111="    //% group=&quot;Motor&quot; weight=6" line112="    //% distance.min=0 distance.max=1000 distance.defl=10" line113="    //% inlineInputMode = inline" line114="    export function motorRunDistance(mID: motorID, direction: motorDirection, distance: number): void {" line115="        //设置距离" line116="        const disAddr2 = mID + 0x07;" line117="        let disBuff2 = pins.createBuffer(3);" line118="        disBuff2.setNumber(NumberFormat.UInt8BE, 0, disAddr2);" line119="        disBuff2.setNumber(NumberFormat.UInt8BE, 1, (distance &gt;&gt; 8) &amp; 0xFF);" line120="        disBuff2.setNumber(NumberFormat.UInt8BE, 2, distance &amp; 0xFF);" line121="        pins.i2cWriteBuffer(i2cAddress, disBuff2);" line122="        // 发送运动指令" line123="        const cmdAddr3 = mID + 0x03;" line124="        let cmdBuff6 = pins.createBuffer(2);" line125="        cmdBuff6.setNumber(NumberFormat.UInt8BE, 0, cmdAddr3);" line126="        cmdBuff6.setNumber(NumberFormat.UInt8BE, 1, direction + 6);" line127="        pins.i2cWriteBuffer(i2cAddress, cmdBuff6);" line128="    }" line129="" line130="    //% blockId=motorRunAngle" line131="    //% block=&quot;run motor %mID  %direction %angle degrees&quot;" line132="    //% group=&quot;Motor&quot; weight=5" line133="    //% angle.min=0 angle.max=3600 angle.defl=90" line134="    //% inlineInputMode = inline" line135="    export function motorRunAngle(mID: motorID, direction: motorDirection, angle: number): void {" line136="        //设置偏移角度" line137="        const disAddr3 = mID + 0x06;" line138="        let disBuff3 = pins.createBuffer(3);" line139="        disBuff3.setNumber(NumberFormat.UInt8BE, 0, disAddr3);" line140="        disBuff3.setNumber(NumberFormat.UInt8BE, 1, (angle &gt;&gt; 8) &amp; 0xFF);" line141="        disBuff3.setNumber(NumberFormat.UInt8BE, 2, angle &amp; 0xFF);" line142="        pins.i2cWriteBuffer(i2cAddress, disBuff3);" line143="        // 发送运动指令" line144="        const cmdAddr4 = mID + 0x03;" line145="        let cmdBuff7 = pins.createBuffer(2);" line146="        cmdBuff7.setNumber(NumberFormat.UInt8BE, 0, cmdAddr4);" line147="        cmdBuff7.setNumber(NumberFormat.UInt8BE, 1, direction + 4);" line148="        pins.i2cWriteBuffer(i2cAddress, cmdBuff7);" line149="    }" line150="" line151="    //% blockId=motorRunSpeed" line152="    //% block=&quot;run motor %mID go %direction at speed %speed&quot;" line153="    //% group=&quot;Motor&quot; weight=4" line154="    //% speed.min=0 speed.max=100 speed.defl=50" line155="    export function motorRunSpeed(mID: motorID, direction: motorDirection, speed: number): void {" line156="        // 设置速度" line157="        const spAddr4 = mID + 0x04;" line158="        let spBuff4 = pins.createBuffer(3);" line159="        spBuff4.setNumber(NumberFormat.UInt8BE, 0, spAddr4);" line160="        spBuff4.setNumber(NumberFormat.UInt8BE, 1, (speed &gt;&gt; 8) &amp; 0xFF);" line161="        spBuff4.setNumber(NumberFormat.UInt8BE, 2, speed &amp; 0xFF);" line162="        pins.i2cWriteBuffer(i2cAddress, spBuff4);" line163="        // 发送运动指令" line164="        const cmdAddr5 = mID + 0x03;" line165="        let cmdBuff8 = pins.createBuffer(2);" line166="        cmdBuff8.setNumber(NumberFormat.UInt8BE, 0, cmdAddr5);" line167="        cmdBuff8.setNumber(NumberFormat.UInt8BE, 1, direction);" line168="        pins.i2cWriteBuffer(i2cAddress, cmdBuff8);" line169="    }" line170="    //% blockId=motorStop" line171="    //% block=&quot;stop motor %mID&quot;" line172="    //% group=&quot;Motor&quot; weight=3" line173="    export function motorStop(mID: motorID): void {" line174="        // 发送停止运动指令" line175="        const cmdAddr6 = mID + 0x03;" line176="        let cmdBuff9 = pins.createBuffer(2);" line177="        cmdBuff9.setNumber(NumberFormat.UInt8BE, 0, cmdAddr6);" line178="        cmdBuff9.setNumber(NumberFormat.UInt8BE, 1, 0);" line179="        pins.i2cWriteBuffer(i2cAddress, cmdBuff9);" line180="    }" line181="" line182="    //#########################################################################" line183="    //##################################舵机#################################" line184="    //#########################################################################" line185="" line186="    //% blockId=servo1Set" line187="    //% block=&quot;设置180舵机 %pin 角度为 %value °&quot;" line188="    //% value.min=0 value.max=180 value.defl=90" line189="    //% group=&quot;Servo Motor&quot; weight=9" line190="    export function servo1Set(pin: ServoPin, value: number): void {" line191="        pins.servoWritePin(pin, value)" line192="    }" line193="" line194="    //% blockId=servo1Stop" line195="    //% block=&quot;停止180舵机 %servoPin&quot;" line196="    //% group=&quot;Servo Motor&quot; weight=6" line197="    export function servo1Stop(servoPin: ServoPin): void {" line198="        pins.digitalWritePin(servoPin, 0)" line199="    }" line200="" line201="    //% blockId=servo360_run" line202="    //% block=&quot;360舵机 %pin 以速度 %speed %direction 转动&quot;" line203="    //% speed.min=0 speed.max=100 speed.defl=50" line204="    //% group=&quot;Servo Motor&quot; weight=5" line205="    export function runServo360(pin: ServoPin, speed: number, direction: RotationDirection ): void {" line206="        // 限制速度范围" line207="        speed = Math.min(100, Math.max(0, speed))" line208="" line209="        // 计算脉冲宽度" line210="        // 中间位置：1.5ms (1500µs) = 停止" line211="        // 顺时针方向：1.0ms (1000µs) = 全速逆时针" line212="        // 逆时针方向：2.0ms (2000µs) = 全速顺时针" line213="        let pulseWidth: number" line214="" line215="        if (speed === 0) {" line216="            pulseWidth = 1500" line217="        } else {" line218="            if (direction === RotationDirection.Clockwise) {" line219="                // 顺时针方向：脉冲宽度大于1500µs" line220="                // 1500-2000µs 对应速度 0-100" line221="                pulseWidth = 1500 + (speed * 5)" line222="            } else {" line223="                // 逆时针方向：脉冲宽度小于1500µs" line224="                // 1000-1500µs 对应速度 0-100" line225="                pulseWidth = 1500 - (speed * 5)" line226="            }" line227="        }" line228="        // 设置脉冲宽度" line229="        pins.servoSetPulse(pin, pulseWidth)" line230="    }" line231="    //% blockId=servo360_run_with_duration" line232="    //% block=&quot;360舵机 %pin 以速度 %speed %direction 转动 %duration 秒&quot;" line233="    //% speed.min=0 speed.max=100 speed.defl=50" line234="    //% duration.min=0 duration.max=100 duration.defl=1" line235="    //% group=&quot;Servo Motor&quot; weight=4" line236="    export function runServo360ForDuration(pin: ServoPin, speed: number, direction: RotationDirection, duration: number): void {" line237="        // 启动舵机" line238="        runServo360(pin, speed, direction)" line239="" line240="        // 等待指定时间" line241="        basic.pause(duration * 1000)" line242="" line243="        // 停止舵机" line244="        stopServo360(pin)" line245="    }" line246="" line247="    //% blockId=servo360_stop" line248="    //% block=&quot;停止360舵机 %pin&quot;" line249="    //% group=&quot;&quot;Servo Motor&quot; weight=3" line250="    export function stopServo360(pin: ServoPin): void {" line251="        // 设置脉冲宽度为1.5ms停止" line252="        pins.servoSetPulse(pin, 1500)" line253="    }" line254="    " line255="    //#########################################################################" line256="    //##################################灯条#################################" line257="    //#########################################################################" line258="    // RGB LED控制类" line259="    class WS2812BStrip {" line260="        private buffer: Buffer" line261="        private pin: DigitalPin" line262="        private length: number" line263="        private brightness: number = 255" line264="" line265="        constructor(pin: DigitalPin, length: number) {" line266="            this.pin = pin" line267="            this.length = length" line268="            // 每个LED需要3个字节 (RGB)" line269="            this.buffer = pins.createBuffer(length * 3)" line270="            // 初始化引脚" line271="            pins.digitalWritePin(pin, 0)" line272="        }" line273="" line274="        // 设置单个LED的RGB颜色" line275="        setPixelColor(index: number, rgb: number): void {" line276="            if (index &lt; 0 || index &gt;= this.length) return" line277="" line278="            let r = (rgb &gt;&gt; 16) &amp; 0xFF" line279="            let g = (rgb &gt;&gt; 8) &amp; 0xFF" line280="            let b = rgb &amp; 0xFF" line281="" line282="            // 应用亮度" line283="            if (this.brightness &lt; 255) {" line284="                r = (r * this.brightness) &gt;&gt; 8" line285="                g = (g * this.brightness) &gt;&gt; 8" line286="                b = (b * this.brightness) &gt;&gt; 8" line287="            }" line288="" line289="            let offset = index * 3" line290="            // WS2812B使用GRB顺序" line291="            this.buffer[offset] = g     // G" line292="            this.buffer[offset + 1] = r // R" line293="            this.buffer[offset + 2] = b // B" line294="        }" line295="" line296="        // 显示所有LED" line297="        show(): void {" line298="            // 使用ws2812b库发送数据" line299="            ws2812b.sendBuffer(this.buffer, this.pin)" line300="        }" line301="" line302="        // 清除所有LED" line303="        clear(): void {" line304="            for (let i = 0; i &lt; this.buffer.length; i++) {" line305="                this.buffer[i] = 0" line306="            }" line307="        }" line308="" line309="        // 设置亮度" line310="        setBrightness(brightness: number): void {" line311="            this.brightness = Math.min(255, Math.max(0, brightness))" line312="        }" line313="    }" line314="" line315="    // 全局变量存储当前灯条" line316="    let currentStrip: WS2812BStrip" line317="    let currentLEDCount: number = 8" line318="" line319="    //% blockId=ws2812b_init" line320="    //% block=&quot;初始化灯条 引脚 %pin 灯数 %ledCount&quot;" line321="    //% ledCount.min=1 ledCount.max=50 ledCount.defl=8" line322="    //% group=&quot;LED&quot; weight=9" line323="    export function initStrip(pin: ServoPin, ledCount: number): void {" line324="        currentStrip = new WS2812BStrip(pin as number, ledCount)" line325="        currentLEDCount = ledCount" line326="    }" line327="" line328="    //% blockId=ws2812b_set_brightness" line329="    //% block=&quot;设置亮度 %brightness&quot;" line330="    //% brightness.min=0 brightness.max=255 brightness.defl=128" line331="    //% group=&quot;LED&quot; weight=8" line332="    export function setBrightness(brightness: number): void {" line333="        if (currentStrip) {" line334="            currentStrip.setBrightness(brightness)" line335="        }" line336="    }" line337="" line338="    //% blockId=ws2812b_set_all" line339="    //% block=&quot;设置全部灯为颜色 %color&quot;" line340="    //% group=&quot;LED&quot; weight=7" line341="    export function setAllColor(color: Colors): void {" line342="        if (currentStrip) {" line343="            for (let j = 0; j &lt; currentLEDCount; j++) {" line344="                currentStrip.setPixelColor(j, color)" line345="            }" line346="            currentStrip.show()" line347="        }" line348="    }" line349="" line350="    //% blockId=ws2812b_set_all_rgb" line351="    //% block=&quot;设置全部灯RGB R %red G %green B %blue&quot;" line352="    //% red.min=0 red.max=255 red.defl=255" line353="    //% green.min=0 green.max=255 green.defl=0" line354="    //% blue.min=0 blue.max=255 blue.defl=0" line355="    //% group=&quot;LED&quot; weight=6" line356="    export function setAllRGB(red: number, green: number, blue: number): void {" line357="        if (currentStrip) {" line358="            let rgb = (red &lt;&lt; 16) | (green &lt;&lt; 8) | blue" line359="            for (let k = 0; k &lt; currentLEDCount; k++) {" line360="                currentStrip.setPixelColor(k, rgb)" line361="            }" line362="            currentStrip.show()" line363="        }" line364="    }" line365="" line366="    //% blockId=ws2812b_set_led" line367="    //% block=&quot;设置第 %index 个灯为颜色 %color&quot;" line368="    //% index.min=0 index.defl=0" line369="    //% group=&quot;LED&quot; weight=5" line370="    export function setLEDColor(index: number, color: Colors): void {" line371="        if (currentStrip &amp;&amp; index &gt;= 0 &amp;&amp; index &lt; currentLEDCount) {" line372="            currentStrip.setPixelColor(index, color)" line373="            currentStrip.show()" line374="        }" line375="    }" line376="" line377="    //% blockId=ws2812b_set_led_rgb" line378="    //% block=&quot;设置%index灯R %red G %green B %blue&quot;" line379="    //% index.min=0 index.defl=0" line380="    //% red.min=0 red.max=255 red.defl=255" line381="    //% green.min=0 green.max=255 green.defl=0" line382="    //% blue.min=0 blue.max=255 blue.defl=0" line383="    //% inlineInputMode=inline" line384="    //% group=&quot;LED&quot; weight=4" line385="    export function setLEDRGB(index: number, red: number, green: number, blue: number): void {" line386="        if (currentStrip &amp;&amp; index &gt;= 0 &amp;&amp; index &lt; currentLEDCount) {" line387="            let rgb2 = (red &lt;&lt; 16) | (green &lt;&lt; 8) | blue" line388="            currentStrip.setPixelColor(index, rgb2)" line389="            currentStrip.show()" line390="        }" line391="    }" line392="" line393="    //% blockId=ws2812b_clear" line394="    //% block=&quot;熄灭全部灯&quot;" line395="    //% group=&quot;LED&quot; weight=3" line396="    export function clearAll(): void {" line397="        if (currentStrip) {" line398="            currentStrip.clear()" line399="            currentStrip.show()" line400="        }" line401="    }" line402="" line403="    //#########################################################################" line404="    //##################################LCD#################################" line405="    //#########################################################################" line406="    const LCD_ADDRESS = 0x27  // 常见I2C地址，也可能是0x3F" line407="    let lcd_isInitialized = false" line408="" line409="    //% blockId=&quot;lcd1602_init&quot; block=&quot;初始化LCD1602&quot;" line410="    //% group=&quot;LCD1602&quot; weight=100" line411="    export function init(): void {" line412="        // 简化的初始化序列" line413="        basic.pause(50)" line414="        writeCmd(0x33)" line415="        basic.pause(5)" line416="        writeCmd(0x32)" line417="        basic.pause(5)" line418="        writeCmd(0x28)  // 4位模式，2行显示" line419="        basic.pause(5)" line420="        writeCmd(0x0C)  // 显示开，光标关" line421="        basic.pause(5)" line422="        writeCmd(0x06)  // 输入模式" line423="        basic.pause(5)" line424="        writeCmd(0x01)  // 清屏" line425="        basic.pause(5)" line426="" line427="        lcd_isInitialized = true" line428="    }" line429="    //% blockId=&quot;lcd1602_clear&quot; block=&quot;LCD清屏&quot;" line430="    //% group=&quot;LCD1602&quot; weight=90" line431="    export function clear(): void {" line432="        if (!lcd_isInitialized) init()" line433="        writeCmd(0x01)" line434="        basic.pause(2)" line435="    }" line436="" line437="    //% blockId=&quot;lcd1602_show_at&quot; block=&quot;在第%row行第%col列显示%text&quot;" line438="    //% row.min=0 row.max=1 row.defl=0" line439="    //% col.min=0 col.max=15 col.defl=0" line440="    //% group=&quot;LCD1602&quot; weight=80" line441="    export function showAt(row: number, col: number, text: string): void {" line442="        if (!lcd_isInitialized) init()" line443="" line444="        // 限制行列" line445="        row = Math.min(1, Math.max(0, row))" line446="        col = Math.min(15, Math.max(0, col))" line447="" line448="        // 设置光标位置" line449="        let address = col" line450="        if (row == 1) address += 0x40" line451="        writeCmd(0x80 | address)" line452="" line453="        // 显示文本" line454="        for (let l = 0; l &lt; text.length &amp;&amp; l &lt; 16; l++) {" line455="            writeData(text.charCodeAt(l))" line456="        }" line457="    }" line458="" line459="    //% blockId=&quot;lcd1602_show_line&quot; block=&quot;在第%row行显示%text&quot;" line460="    //% row.min=0 row.max=1 row.defl=0" line461="    //% group=&quot;LCD1602&quot; weight=70" line462="    export function showLine(row: number, text: string): void {" line463="        if (!lcd_isInitialized) init()" line464="        showAt(row, 0, text)" line465="    }" line466="" line467="    //% blockId=&quot;lcd1602_show_number&quot; block=&quot;LCD显示数字%num&quot;" line468="    //% group=&quot;LCD1602&quot; weight=60" line469="    export function showNumber(num: number): void {" line470="        if (!lcd_isInitialized) init()" line471="        showLine(0, num.toString())" line472="    }" line473="" line474="    // 内部辅助函数" line475="    function writeCmd(cmd: number): void {" line476="        let high = cmd &amp; 0xF0" line477="        let low = (cmd &lt;&lt; 4) &amp; 0xF0" line478="" line479="        write4bits(high)" line480="        write4bits(low)" line481="    }" line482="" line483="    function writeData(data: number): void {" line484="        let high2 = data &amp; 0xF0" line485="        let low2 = (data &lt;&lt; 4) &amp; 0xF0" line486="" line487="        write4bits(high2 | 0x01)  // RS=1" line488="        write4bits(low2 | 0x01)   // RS=1" line489="    }" line490="" line491="    function write4bits(data: number): void {" line492="        // 发送4位数据，带背光" line493="        let buffer = pins.createBuffer(1)" line494="        buffer[0] = data | 0x08  // 背光开" line495="        pins.i2cWriteBuffer(LCD_ADDRESS, buffer)" line496="" line497="        // 使能脉冲" line498="        buffer[0] = data | 0x0C" line499="        pins.i2cWriteBuffer(LCD_ADDRESS, buffer)" line500="        basic.pause(1)" line501="" line502="        buffer[0] = data &amp; ~0x04" line503="        pins.i2cWriteBuffer(LCD_ADDRESS, buffer)" line504="        basic.pause(1)" line505="    }" line506="" line507="    //#########################################################################" line508="    //##################################传感器#################################" line509="    //#########################################################################" line510="" line511="    //----------------------------------电位器-------------------------------" line512="    //% blockId=potentiometer_read_raw" line513="    //% block=&quot;读取电位器 %pin 原始值&quot;" line514="    //% group=&quot;Potentiometer&quot; weight=99" line515="    export function readRawValue(pin: PotPin): number {" line516="        // 直接读取模拟值，范围0-1023" line517="        return pins.analogReadPin(pin as number)" line518="    }" line519="" line520="    //% blockId=potentiometer_read_percent" line521="    //% block=&quot;读取电位器 %pin 百分比&quot;" line522="    //% group=&quot;Potentiometer&quot; weight=98" line523="    export function readPercentage(pin: PotPin): number {" line524="        // 读取原始值" line525="        let rawValue = pins.analogReadPin(pin as number)" line526="" line527="        // 转换为百分比 0-100" line528="        let percentage = (rawValue * 100) / 1023" line529="" line530="        // 确保在0-100范围内" line531="        percentage = Math.min(100, Math.max(0, percentage))" line532="        return Math.round(percentage)" line533="    }" line534="" line535="    //----------------------------------土壤湿度-------------------------------" line536="    //% blockId=soil_read_raw" line537="    //% block=&quot;读取土壤湿度 %pin 原始值&quot;" line538="    //% group=&quot;Soil Moisture Sensor&quot; weight=89" line539="    export function readRawValueTR(pin: PotPin): number {" line540="        // 直接读取模拟值，范围0-1023" line541="        return pins.analogReadPin(pin as number) " line542="    }" line543="" line544="    //% blockId=soil_read_percent" line545="    //% block=&quot;读取土壤湿度 %pin 百分比&quot;" line546="    //% group=&quot;Soil Moisture Sensor&quot; weight=88" line547="    export function readPercentageTR(pin: PotPin): number {" line548="        // 读取原始值" line549="        let rawValue2 = pins.analogReadPin(pin as number)" line550="" line551="        // 转换为百分比 0-100" line552="        let percentage2 = (rawValue2 * 100) / 1023" line553="" line554="        // 确保在0-100范围内" line555="        percentage2 = Math.min(100, Math.max(0, percentage2))" line556="        return Math.round(percentage2)" line557="    }" line558="" line559="    //----------------------------------按键-------------------------------" line560="    //% blockId=button_is_pressed" line561="    //% block=&quot;按键 %pin 是否按下&quot;" line562="    //% group=&quot;Button&quot; weight=79" line563="    export function isPressed(pin: ServoPin): boolean {" line564="        let value = pins.digitalReadPin(pin as number)" line565="        // 返回 true 表示按下" line566="        return value === 0" line567="    }" line568="" line569="    //----------------------------------超声波-------------------------------" line570="    // 存储引脚配置" line571="    let trigPin: DigitalPin" line572="    let echoPin: DigitalPin" line573="    let ultrasonic_isInitialized = false" line574="" line575="    //% blockId=ultrasonic_init" line576="    //% block=&quot;初始化超声波模块 Trig脚连接 %trig Echo脚连接 %echo&quot;" line577="    //% group=&quot;Ultrasonic&quot; weight=9" line578="    export function initUltrasonic(trig: ServoPin, echo: ServoPin): void {" line579="        trigPin = trig as number" line580="        echoPin = echo as number" line581="        ultrasonic_isInitialized = true" line582="" line583="        // 初始化引脚" line584="        pins.digitalWritePin(trigPin, 0)" line585="        pins.setPull(echoPin, PinPullMode.PullNone)" line586="    }" line587="" line588="    //% blockId=ultrasonic_read_distance" line589="    //% block=&quot;读取超声波距离（厘米）&quot;" line590="    //% group=&quot;Ultrasonic&quot; weight=8" line591="    export function readDistance(): number {" line592="        if (!ultrasonic_isInitialized) {" line593="            return 0" line594="        }" line595="" line596="        // 发送10us的高电平脉冲" line597="        pins.digitalWritePin(trigPin, 0)" line598="        control.waitMicros(2)" line599="        pins.digitalWritePin(trigPin, 1)" line600="        control.waitMicros(10)" line601="        pins.digitalWritePin(trigPin, 0)" line602="" line603="        // 读取高电平持续时间" line604="        // 注意：pins.pulseIn返回的是微秒" line605="        let duration = pins.pulseIn(echoPin, PulseValue.High, 50000)  // 50ms超时" line606="" line607="        // 计算距离（厘米）" line608="        // 声音速度：340m/s = 34000cm/s = 0.034cm/μs" line609="        // 往返距离，所以除以2" line610="        let distance = duration * 0.034 / 2" line611="" line612="        // 限制有效范围（通常超声波模块有效范围2-400cm）" line613="        if (distance &lt; 2 || distance &gt; 400) {" line614="            distance = 0" line615="        }" line616="" line617="        return Math.round(distance)" line618="    }" line619="" line620="    //----------------------------------巡线-------------------------------" line621="    // 存储三个传感器的引脚" line622="    let leftPin: ServoPin" line623="    let middlePin: ServoPin" line624="    let rightPin: ServoPin" line625="    let line_isInitialized = false" line626="" line627="    // 引脚映射表" line628="    let pinMap: { [key: number]: DigitalPin } = {" line629="        1: DigitalPin.P0,  // 左默认P0" line630="        2: DigitalPin.P1,  // 中默认P1" line631="        3: DigitalPin.P2   // 右默认P2" line632="    }" line633="" line634="    //% blockId=linetracking_init" line635="    //% block=&quot;初始化巡线传感器|左引脚%left|中引脚%middle|右引脚%right&quot;" line636="    //% group=&quot;Line Tracking Sensor&quot; weight=59" line637="    export function initSensors(left: ServoPin, middle: ServoPin, right: ServoPin): void {" line638="        pinMap[1] = left as number" line639="        pinMap[2] = middle as number" line640="        pinMap[3] = right as number" line641="        line_isInitialized = true" line642="    }" line643="    //% blockId=linetracking_detect  " line644="    //% block=&quot;%position 传感器检测到黑线&quot;" line645="    //% group=&quot;Line Tracking Sensor&quot; weight=58" line646="    export function detectLine(position: SensorSide): boolean {" line647="        if (!line_isInitialized) return false" line648="        let pin = pinMap[position]" line649="        return pins.digitalReadPin(pin) === 1" line650="    }" line651="" line652="    //% blockId=linetracking_read_value" line653="    //% block=&quot;读取%position 传感器值&quot;" line654="    //% group=&quot;Line Tracking Sensor&quot; weight=57" line655="    export function readSensorValue(position: SensorSide): number {" line656="        if (!line_isInitialized) return 0" line657="        let pin2 = pinMap[position]" line658="        return pins.digitalReadPin(pin2)" line659="    }" line660="" line661="    //----------------------------------摇杆-------------------------------" line662="    //% blockId=rocker" line663="    //% block=&quot;Joystick %direction moved&quot;" line664="    //% group=&quot;Roker&quot; weight=49" line665="    export function rocker(direction: rocket): number {" line666="        let GetBuff = pins.createBuffer(3)" line667="        GetBuff = pins.i2cReadBuffer(97, 3)" line668="        let re = GetBuff.getNumber(NumberFormat.Int8BE, direction)" line669="        if (direction == 2) {" line670="            return -re" line671="        } else {" line672="            return re" line673="        }" line674="    }" line675="    //% blockId=rockerori" line676="    //% block=&quot;Joystick detected %orientation&quot;" line677="    //% group=&quot;Roker&quot; weight=48" line678="    export function rockerori(orientation: rock): boolean {" line679="        let GetBuff2 = pins.createBuffer(3)" line680="        GetBuff2 = pins.i2cReadBuffer(97, 3)" line681="        let ud = GetBuff2.getNumber(NumberFormat.Int8BE, 2)" line682="        let lr = GetBuff2.getNumber(NumberFormat.Int8BE, 1)" line683="        let flag" line684="        if (orientation == 1) {" line685="            if (ud &gt; 50)" line686="                flag = true" line687="            else" line688="                flag = false" line689="        }" line690="        if (orientation == 2) {" line691="            if (ud &lt; -50)" line692="                flag = true" line693="            else" line694="                flag = false" line695="        }" line696="        if (orientation == 4) {" line697="            if (lr &lt; -50)" line698="                flag = true" line699="            else" line700="                flag = false" line701="        }" line702="        if (orientation == 3) {" line703="            if (lr &gt; 50)" line704="                flag = true" line705="            else" line706="                flag = false" line707="        }" line708="        return flag" line709="" line710="    }" line711="" line712="" line713="    //----------------------------------颜色传感器-------------------------------" line714="    // ===== VEML6040 I2C 地址 =====" line715="    const VEML6040_ADDR = 0x10" line716="" line717="    // ===== 寄存器地址 =====" line718="    const REG_CONF = 0x00" line719="    const REG_RED = 0x08" line720="    const REG_GREEN = 0x09" line721="    const REG_BLUE = 0x0A" line722="    const REG_WHITE = 0x0B" line723="" line724="    // ===== 积分时间 =====" line725="    const IT_320MS = 0x30" line726="" line727="    // ===== 自动 / 强制 =====" line728="    const AF_AUTO = 0x00" line729="    const SD_ENABLE = 0x00" line730="" line731="    let veml_initialized = false" line732="" line733="    function setConfiguration() {" line734="        let buf = pins.createBuffer(3)" line735="        buf[0] = REG_CONF;" line736="        buf[1] = IT_320MS | AF_AUTO | SD_ENABLE;" line737="        buf[2] = 0;" line738="        pins.i2cWriteBuffer(VEML6040_ADDR, buf, false);" line739="    }" line740="" line741="    //读取颜色值" line742="    function readReg(reg: number): number {" line743="        let regBuf = pins.createBuffer(1)" line744="        regBuf[0] = reg" line745="" line746="        pins.i2cWriteBuffer(VEML6040_ADDR, regBuf, true)" line747="        basic.pause(5)" line748="        " line749="        let data = pins.i2cReadBuffer(VEML6040_ADDR, 2, false)" line750="" line751="        return data[0] | (data[1] &lt;&lt; 8)" line752="    }" line753="" line754="    let cacheR = 0" line755="    let cacheG = 0" line756="    let cacheB = 0" line757="    let cacheW = 0" line758="" line759="    let lastReadTime = 0" line760="    const READ_INTERVAL = 320" line761="" line762="    function updateRGB() {" line763="" line764="        if (!veml_initialized) {" line765="            init_veml()" line766="        }" line767="" line768="        let now = control.millis()" line769="" line770="        // 控制读取频率" line771="        if (now - lastReadTime &lt; READ_INTERVAL) return" line772="" line773="        let s = readReg(REG_RED)" line774="        let h = readReg(REG_GREEN)" line775="        let c = readReg(REG_BLUE)" line776="        let w = readReg(REG_WHITE)" line777="" line778="        // 防止异常值" line779="        if (s == 0 &amp;&amp; h == 0 &amp;&amp; c == 0 &amp;&amp; w == 0) return" line780="" line781="        cacheR = s" line782="        cacheG = h" line783="        cacheB = c" line784="        cacheW = w" line785="        serial.writeLine(&quot;R=&quot; + s + &quot; G=&quot; + h + &quot; B=&quot; + c + &quot; W=&quot; + w)" line786="" line787="        lastReadTime = now" line788="    }" line789="" line790="    //判断颜色" line791="    export function getColor(): DetectedColor {" line792="" line793="        updateRGB()" line794="" line795="        let t = cacheR" line796="        let m = cacheG" line797="        let d = cacheB" line798="        let a = cacheW" line799="" line800="        // ===== 黑 / 白 优先 =====" line801="        if (a &lt; 50) return DetectedColor.Black" line802="" line803="        if (a &gt; 2000 &amp;&amp; Math.abs(t - m) &lt; 200 &amp;&amp; Math.abs(m - d) &lt; 200) {" line804="            return DetectedColor.White" line805="        }" line806="" line807="        let rgb3 = [t, m, d]" line808="" line809="        let minDist = 999999" line810="        let result = DetectedColor.White" line811="" line812="        // ⭐ 样本（你可以自己调）" line813="        let samples: { color: DetectedColor, rgb: number[] }[] = [" line814="            { color: DetectedColor.Red, rgb: [5000, 2000, 1000] }," line815="            { color: DetectedColor.Green, rgb: [6000, 5000, 2000] }," line816="            { color: DetectedColor.Blue, rgb: [3000, 3000, 2000] }," line817="            { color: DetectedColor.Yellow, rgb: [4000, 4000, 500] }," line818="            { color: DetectedColor.Purple, rgb: [3000, 800, 3000] }" line819="" line820="        ]" line821="" line822="        for (let u of samples) {" line823="" line824="            let dr = t - u.rgb[0]" line825="            let dg = m - u.rgb[1]" line826="            let db = d - u.rgb[2]" line827="" line828="            let dist = Math.sqrt(dr * dr + dg * dg + db * db)" line829="" line830="            if (dist &lt; minDist) {" line831="                minDist = dist" line832="                result = u.color" line833="            }" line834="        }" line835="" line836="        return result" line837="    }" line838="" line839="    //% blockId=init_veml" line840="    //% block=&quot;init VEML6040&quot;" line841="    //% group=&quot;Color Sensor&quot; weight=39" line842="    export function init_veml(): void {" line843="        if (!veml_initialized) {" line844="            setConfiguration();" line845="            // 等待时间" line846="            basic.pause(320);" line847="            veml_initialized = true" line848="        }" line849="    }" line850="" line851="    //% blockId=isColorDetected" line852="    //% block=&quot;识别到颜色 %color&quot;" line853="    //% group=&quot;Color Sensor&quot; weight=38" line854="    export function isColorDetected(color: DetectedColor): boolean {" line855="        return getColor() == color" line856="    }" line857="" line858="    //% blockId=readRGBValue" line859="    //% block=&quot;读取 %channel 值&quot;" line860="    //% group=&quot;Color Sensor&quot; weight=37" line861="    export function readRGBValue(channel: enRGB): number {" line862="        updateRGB()" line863="" line864="        // ⭐ 需要你实际测一下（很重要）" line865="        const MAX_R = 6000" line866="        const MAX_G = 3000" line867="        const MAX_B = 2000" line868="" line869="        let nr = Math.round(cacheR * 255 / MAX_R)" line870="        let ng = Math.round(cacheG * 255 / MAX_G)" line871="        let nb = Math.round(cacheB * 255 / MAX_B)" line872="" line873="        // 限制范围" line874="        if (nr &gt; 255) nr = 255" line875="        if (ng &gt; 255) ng = 255" line876="        if (nb &gt; 255) nb = 255" line877="" line878="        switch (channel) {" line879="            case enRGB.Red: return nr" line880="            case enRGB.Green: return ng" line881="            case enRGB.Blue: return nb" line882="            default: return 0" line883="        }" line884="        " line885="    }" line886="" line887="    //% blockId=readWhiteValue" line888="    //% block=&quot;读取亮度值&quot;" line889="    //% group=&quot;Color Sensor&quot; weight=36" line890="    export function readWhiteValue(): number {" line891="        return readReg(REG_WHITE)" line892="    }" line893="" line894="}" numlines="895"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>