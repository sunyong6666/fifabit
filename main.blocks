<xml xmlns="https://developers.google.com/blockly/xml"><variables><variable id="pSv8vHo~~Yx[43BW9NK;">i2cAddress</variable></variables><block type="pxt-on-start" id="h{kAC5rd/mUo7zDWDiu}" x="20" y="20"><statement name="HANDLER"><block type="variables_set" id="dY!#cQKVFFUT15@ahxFV"><field name="VAR" id="pSv8vHo~~Yx[43BW9NK;">i2cAddress</field><comment pinned="false" h="80" w="160">I2C设备地址</comment><value name="VALUE"><shadow type="math_number" id="vX^#[UDB^6$q{/#}z6+g"><field name="NUM">9</field></shadow></value><next><block type="typescript_statement" id="L_-Hg{_vGNJCDFJn2su]"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType {" line1="    //% block=&quot;forward&quot;" line2="    type1 = 1," line3="    //% block=&quot;backward&quot;" line4="    type2 = 2," line5="    //% block=&quot;left&quot;" line6="    type3 = 3," line7="    //% block=&quot;right&quot;" line8="    type4 = 4" line9="}" numlines="10"></mutation><next><block type="typescript_statement" id=".y*/05@T8a~x!Qj80V-r"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType1 {" line1="    //% block=&quot;forward&quot;" line2="    type1 = 5," line3="    //% block=&quot;backward&quot;" line4="    type2 = 6" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="GHc_{P$mt#WGOTF}h(Yb"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motionType2 {" line1="    //% block=&quot;left&quot;" line2="    type1 = 9," line3="    //% block=&quot;right&quot;" line4="    type2 = 10" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="OC3Bx`oK[FXq/Z;3eJdo"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motorID {" line1="    //% block=&quot;1&quot;" line2="    motor0 = 0x50," line3="    //% block=&quot;2&quot;" line4="    motor1 = 0x6E" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="F%%eEL,?-YU}[bfA%1kS"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum motorDirection {" line1="    //% block=&quot;forward&quot;" line2="    clockwise = 1," line3="    //% block=&quot;reverse&quot;" line4="    counterclockwise = 2" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="uEb_GhS$zCMx;uTqP8tp"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum ServoPin {" line1="    //% block=&quot;P0&quot;" line2="    P0 = DigitalPin.P0," line3="    //% block=&quot;P1&quot;" line4="    P1 = DigitalPin.P1," line5="    //% block=&quot;P2&quot;" line6="    P2 = DigitalPin.P2," line7="    //% block=&quot;P8&quot;" line8="    P8 = DigitalPin.P8," line9="    //% block=&quot;P12&quot;" line10="    P12 = DigitalPin.P12," line11="    //% block=&quot;P13&quot;" line12="    P13 = DigitalPin.P13," line13="    //% block=&quot;P15&quot;" line14="    P15 = DigitalPin.P15," line15="    //% block=&quot;P16&quot;" line16="    P16 = DigitalPin.P16" line17="}" numlines="18"></mutation><next><block type="typescript_statement" id="GtL%`!mJ}+Zb/)8ziPZB"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum RotationDirection {" line1="    //% block=&quot;clockwise&quot;" line2="    Clockwise = 1," line3="    //% block=&quot;counterclockwise&quot;" line4="    Counterclockwise = -1" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="_QZoKNRu6.eASi8(#)gr"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum Colors {" line1="    //% block=&quot;red&quot;" line2="    Red = 0xFF0000," line3="    //% block=&quot;orange&quot;" line4="    Orange = 0xFF7F00," line5="    //% block=&quot;yellow&quot;" line6="    Yellow = 0xFFFF00," line7="    //% block=&quot;green&quot;" line8="    Green = 0x00FF00," line9="    //% block=&quot;cyan&quot;" line10="    Cyan = 0x00FFFF," line11="    //% block=&quot;blue&quot;" line12="    Blue = 0x0000FF," line13="    //% block=&quot;purple&quot;" line14="    Purple = 0x7F00FF," line15="    //% block=&quot;white&quot;" line16="    White = 0xFFFFFF," line17="    //% block=&quot;black&quot;" line18="    Black = 0x000000" line19="}" numlines="20"></mutation><next><block type="typescript_statement" id="PX}ptcxsO}@yDHIYXqb-"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace FIFAbit {" line1="    //#########################################################################" line2="    //################################## 运动（双电机）#########################" line3="    //#########################################################################" line4="    //% blockId=motionSpeed" line5="    //% block=&quot;move %mtype at speed %mspeed&quot;" line6="    //% group=&quot;Motion&quot; weight=9" line7="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line8="    export function motionSpeed(mtype: motionType, mspeed: number): void {" line9="        const spAddr = 0x8C + 0x01;//设置速度" line10="        let spBuff = pins.createBuffer(5);" line11="        spBuff.setNumber(NumberFormat.UInt8BE, 0, spAddr);" line12="        spBuff.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line13="        spBuff.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line14="        spBuff.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line15="        spBuff.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line16="        pins.i2cWriteBuffer(i2cAddress, spBuff);" line17="        const regAddr = 0x8C + 0x00;//执行" line18="        let cmdBuff = pins.createBuffer(2);" line19="        cmdBuff.setNumber(NumberFormat.UInt8BE, 0, regAddr);" line20="        cmdBuff.setNumber(NumberFormat.UInt8BE, 1, mtype);" line21="        pins.i2cWriteBuffer(i2cAddress, cmdBuff);" line22="    }" line23="    //% blockId=motionDistance" line24="    //% block=&quot;move %mtype at speed %mspeed for %distance cm&quot;" line25="    //% group=&quot;Motion&quot; weight=8" line26="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line27="    //% distance.min=0 distance.max=1000 distance.defl=10" line28="    export function motionDistance(mtype: motionType1, mspeed: number, distance: number): void {" line29="        const spAddr2 = 0x8C + 0x01;//设置速度" line30="        let spBuff2 = pins.createBuffer(5);" line31="        spBuff2.setNumber(NumberFormat.UInt8BE, 0, spAddr2);" line32="        spBuff2.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line33="        spBuff2.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line34="        spBuff2.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line35="        spBuff2.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line36="        pins.i2cWriteBuffer(i2cAddress, spBuff2);" line37="        const disAddr = 0x8C + 0x02;//设置距离" line38="        let disBuff = pins.createBuffer(3);" line39="        disBuff.setNumber(NumberFormat.UInt8BE, 0, disAddr);" line40="        disBuff.setNumber(NumberFormat.UInt8BE, 1, (distance &gt;&gt; 8) &amp; 0xFF);" line41="        disBuff.setNumber(NumberFormat.UInt8BE, 2, distance &amp; 0xFF);" line42="        pins.i2cWriteBuffer(i2cAddress, disBuff);" line43="        const regAddr2 = 0x8C + 0x00;//执行" line44="        let cmdBuff2 = pins.createBuffer(2);" line45="        cmdBuff2.setNumber(NumberFormat.UInt8BE, 0, regAddr2);" line46="        cmdBuff2.setNumber(NumberFormat.UInt8BE, 1, mtype);" line47="        pins.i2cWriteBuffer(i2cAddress, cmdBuff2);" line48="    }" line49="    //% blockId=motionAngle" line50="    //% block=&quot;move %mtype at speed %mspeed for %angle °&quot;" line51="    //% group=&quot;Motion&quot; weight=7" line52="    //% mspeed.min=0 mspeed.max=100 mspeed.defl=50" line53="    //% angle.min=0 angle.max=1000 angle.defl=90" line54="    export function motionAngle(mtype: motionType2, mspeed: number, angle: number): void {" line55="        const spAddr3 = 0x8C + 0x01;//设置速度" line56="        let spBuff3 = pins.createBuffer(5);" line57="        spBuff3.setNumber(NumberFormat.UInt8BE, 0, spAddr3);" line58="        spBuff3.setNumber(NumberFormat.UInt8BE, 1, (mspeed &gt;&gt; 8) &amp; 0xFF);" line59="        spBuff3.setNumber(NumberFormat.UInt8BE, 2, mspeed &amp; 0xFF);" line60="        spBuff3.setNumber(NumberFormat.UInt8BE, 3, (mspeed &gt;&gt; 8) &amp; 0xFF);" line61="        spBuff3.setNumber(NumberFormat.UInt8BE, 4, mspeed &amp; 0xFF);" line62="        pins.i2cWriteBuffer(i2cAddress, spBuff3);" line63="        const disAddr2 = 0x8C + 0x04;//设置角度" line64="        let disBuff2 = pins.createBuffer(3);" line65="        disBuff2.setNumber(NumberFormat.UInt8BE, 0, disAddr2);" line66="        disBuff2.setNumber(NumberFormat.UInt8BE, 1, (angle &gt;&gt; 8) &amp; 0xFF);" line67="        disBuff2.setNumber(NumberFormat.UInt8BE, 2, angle &amp; 0xFF);" line68="        pins.i2cWriteBuffer(i2cAddress, disBuff2);" line69="        const regAddr3 = 0x8C + 0x00;//执行" line70="        let cmdBuff3 = pins.createBuffer(2);" line71="        cmdBuff3.setNumber(NumberFormat.UInt8BE, 0, regAddr3);" line72="        cmdBuff3.setNumber(NumberFormat.UInt8BE, 1, mtype);" line73="        pins.i2cWriteBuffer(i2cAddress, cmdBuff3);" line74="    }" line75="    //% blockId=motionStop" line76="    //% block=&quot;stop motion&quot;" line77="    //% group=&quot;Motion&quot; weight=6" line78="    export function motionStop(): void {" line79="        const regAddr4 = 0x8C + 0x00;//执行" line80="        let cmdBuff4 = pins.createBuffer(2);" line81="        cmdBuff4.setNumber(NumberFormat.UInt8BE, 0, regAddr4);" line82="        cmdBuff4.setNumber(NumberFormat.UInt8BE, 1, 0);" line83="        pins.i2cWriteBuffer(i2cAddress, cmdBuff4);" line84="    }" line85="    //#########################################################################" line86="    //##################################单电机#################################" line87="    //#########################################################################" line88="    //% blockId=motorGetSpeed" line89="    //% block=&quot;get motor %mID speed&quot;" line90="    //% group=&quot;Motor&quot; weight=9" line91="    export function motorGetSpeed(mID: motorID): number {" line92="        // 发送指令" line93="        const cmdAddr = mID + 0x01;" line94="        let cmdBuff5 = pins.createBuffer(1);" line95="        cmdBuff5.setNumber(NumberFormat.UInt8BE, 0, cmdAddr);" line96="        pins.i2cWriteBuffer(i2cAddress, cmdBuff5);" line97="        // 拼接 2 字节为 16 位整数" line98="        // let readBuff = pins.createBuffer(2);" line99="        // readBuff = pins.i2cReadBuffer(i2cAddress, 2);" line100="        // let highByte = readBuff.getNumber(NumberFormat.UInt8BE, 0);" line101="        // let lowByte = readBuff.getNumber(NumberFormat.UInt8BE, 1);" line102="        // let speed = ((highByte &amp; 0xFF) &lt;&lt; 8) | (lowByte &amp; 0xFF);" line103="" line104="        // 读取2字节数据" line105="        let readBuff = pins.createBuffer(2);" line106="        readBuff = pins.i2cReadBuffer(i2cAddress, 2);" line107="        // 将2个字节作为有符号16位整数解析" line108="        let speed = readBuff.getNumber(NumberFormat.Int16BE, 0);" line109="        return speed; " line110="    }" line111="    //% blockId=motorSetSpeed" line112="    //% block=&quot;set motor %mID speed to %speed&quot;" line113="    //% group=&quot;Motor&quot; weight=8" line114="    //% speed.min=0 speed.max=100 speed.defl=50" line115="    export function motorSetSpeed(mID: motorID, speed: number): void {" line116="        // 设置速度" line117="        const spAddr4 = mID + 0x04;" line118="        let spBuff4 = pins.createBuffer(3);" line119="        spBuff4.setNumber(NumberFormat.UInt8BE, 0, spAddr4);" line120="        spBuff4.setNumber(NumberFormat.UInt8BE, 1, (speed &gt;&gt; 8) &amp; 0xFF);" line121="        spBuff4.setNumber(NumberFormat.UInt8BE, 2, speed &amp; 0xFF);" line122="        pins.i2cWriteBuffer(i2cAddress, spBuff4);" line123="    }" line124="    //% blockId=motorRun" line125="    //% block=&quot;run motor %mID %direction&quot;" line126="    //% group=&quot;Motor&quot; weight=7" line127="    export function motorRun(mID: motorID, direction: motorDirection): void {" line128="        // 发送运动指令" line129="        const cmdAddr2 = mID + 0x03;" line130="        let cmdBuff6 = pins.createBuffer(2);" line131="        cmdBuff6.setNumber(NumberFormat.UInt8BE, 0, cmdAddr2);" line132="        cmdBuff6.setNumber(NumberFormat.UInt8BE, 1, direction);" line133="        pins.i2cWriteBuffer(i2cAddress, cmdBuff6);" line134="    }" line135="    //% blockId=motorRunDistance" line136="    //% block=&quot;run motor %mID  %direction for %distance cm&quot;" line137="    //% group=&quot;Motor&quot; weight=6" line138="    //% distance.min=0 distance.max=1000 distance.defl=10" line139="    //% inlineInputMode = inline" line140="    export function motorRunDistance(mID: motorID, direction: motorDirection, distance: number): void {" line141="        //设置距离" line142="        const disAddr3 = mID + 0x07;" line143="        let disBuff3 = pins.createBuffer(3);" line144="        disBuff3.setNumber(NumberFormat.UInt8BE, 0, disAddr3);" line145="        disBuff3.setNumber(NumberFormat.UInt8BE, 1, (distance &gt;&gt; 8) &amp; 0xFF);" line146="        disBuff3.setNumber(NumberFormat.UInt8BE, 2, distance &amp; 0xFF);" line147="        pins.i2cWriteBuffer(i2cAddress, disBuff3);" line148="        // 发送运动指令" line149="        const cmdAddr3 = mID + 0x03;" line150="        let cmdBuff7 = pins.createBuffer(2);" line151="        cmdBuff7.setNumber(NumberFormat.UInt8BE, 0, cmdAddr3);" line152="        cmdBuff7.setNumber(NumberFormat.UInt8BE, 1, direction + 6);" line153="        pins.i2cWriteBuffer(i2cAddress, cmdBuff7);" line154="    }" line155="" line156="    //% blockId=motorRunAngle" line157="    //% block=&quot;run motor %mID  %direction %angle °&quot;" line158="    //% group=&quot;Motor&quot; weight=5" line159="    //% angle.min=0 angle.max=3600 angle.defl=90" line160="    //% inlineInputMode = inline" line161="    export function motorRunAngle(mID: motorID, direction: motorDirection, angle: number): void {" line162="        //设置偏移角度" line163="        const disAddr4 = mID + 0x06;" line164="        let disBuff4 = pins.createBuffer(3);" line165="        disBuff4.setNumber(NumberFormat.UInt8BE, 0, disAddr4);" line166="        disBuff4.setNumber(NumberFormat.UInt8BE, 1, (angle &gt;&gt; 8) &amp; 0xFF);" line167="        disBuff4.setNumber(NumberFormat.UInt8BE, 2, angle &amp; 0xFF);" line168="        pins.i2cWriteBuffer(i2cAddress, disBuff4);" line169="        // 发送运动指令" line170="        const cmdAddr4 = mID + 0x03;" line171="        let cmdBuff8 = pins.createBuffer(2);" line172="        cmdBuff8.setNumber(NumberFormat.UInt8BE, 0, cmdAddr4);" line173="        cmdBuff8.setNumber(NumberFormat.UInt8BE, 1, direction + 4);" line174="        pins.i2cWriteBuffer(i2cAddress, cmdBuff8);" line175="    }" line176="" line177="    //% blockId=motorRunSpeed" line178="    //% block=&quot;run motor %mID go %direction at speed %speed&quot;" line179="    //% group=&quot;Motor&quot; weight=4" line180="    //% speed.min=0 speed.max=100 speed.defl=50" line181="    export function motorRunSpeed(mID: motorID, direction: motorDirection, speed: number): void {" line182="        // 设置速度" line183="        const spAddr5 = mID + 0x04;" line184="        let spBuff5 = pins.createBuffer(3);" line185="        spBuff5.setNumber(NumberFormat.UInt8BE, 0, spAddr5);" line186="        spBuff5.setNumber(NumberFormat.UInt8BE, 1, (speed &gt;&gt; 8) &amp; 0xFF);" line187="        spBuff5.setNumber(NumberFormat.UInt8BE, 2, speed &amp; 0xFF);" line188="        pins.i2cWriteBuffer(i2cAddress, spBuff5);" line189="        // 发送运动指令" line190="        const cmdAddr5 = mID + 0x03;" line191="        let cmdBuff9 = pins.createBuffer(2);" line192="        cmdBuff9.setNumber(NumberFormat.UInt8BE, 0, cmdAddr5);" line193="        cmdBuff9.setNumber(NumberFormat.UInt8BE, 1, direction);" line194="        pins.i2cWriteBuffer(i2cAddress, cmdBuff9);" line195="    }" line196="    //% blockId=motorStop" line197="    //% block=&quot;stop motor %mID&quot;" line198="    //% group=&quot;Motor&quot; weight=3" line199="    export function motorStop(mID: motorID): void {" line200="        // 发送停止运动指令" line201="        const cmdAddr6 = mID + 0x03;" line202="        let cmdBuff10 = pins.createBuffer(2);" line203="        cmdBuff10.setNumber(NumberFormat.UInt8BE, 0, cmdAddr6);" line204="        cmdBuff10.setNumber(NumberFormat.UInt8BE, 1, 0);" line205="        pins.i2cWriteBuffer(i2cAddress, cmdBuff10);" line206="    }" line207="" line208="    //#########################################################################" line209="    //##################################舵机#################################" line210="    //#########################################################################" line211="" line212="    //% blockId=servo1Set" line213="    //% block=&quot;set 180° servo %pin to %value °&quot;" line214="    //% value.min=0 value.max=180 value.defl=90" line215="    //% group=&quot;Servo Motor&quot; weight=9" line216="    export function servo1Set(pin: ServoPin, value: number): void {" line217="        pins.servoWritePin(pin, value)" line218="    }" line219="" line220="    //% blockId=servo1Stop" line221="    //% block=&quot;stop 180° servo %pin&quot;" line222="    //% group=&quot;Servo Motor&quot; weight=6" line223="    export function servo1Stop(pin: ServoPin): void {" line224="        pins.digitalWritePin(pin, 0)" line225="    }" line226="" line227="    //% blockId=servo360Run" line228="    //% block=&quot;run 360° servo %pin at speed %speed %direction&quot;" line229="    //% speed.min=0 speed.max=100 speed.defl=50" line230="    //% group=&quot;Servo Motor&quot; weight=5" line231="    export function servo360Run(pin: ServoPin, speed: number, direction: RotationDirection ): void {" line232="        // 限制速度范围" line233="        speed = Math.min(100, Math.max(0, speed))" line234="" line235="        // 计算脉冲宽度" line236="        // 中间位置：1.5ms (1500µs) = 停止" line237="        // 顺时针方向：1.0ms (1000µs) = 全速逆时针" line238="        // 逆时针方向：2.0ms (2000µs) = 全速顺时针" line239="        let pulseWidth: number" line240="" line241="        if (speed === 0) {" line242="            pulseWidth = 1500" line243="        } else {" line244="            if (direction === RotationDirection.Clockwise) {" line245="                // 顺时针方向：脉冲宽度大于1500µs" line246="                // 1500-2000µs 对应速度 0-100" line247="                pulseWidth = 1500 - (speed * 5)" line248="            } else {" line249="                // 逆时针方向：脉冲宽度小于1500µs" line250="                // 1000-1500µs 对应速度 0-100" line251="                pulseWidth = 1500 + (speed * 5)" line252="            }" line253="        }" line254="        // 设置脉冲宽度" line255="        pins.servoSetPulse(pin, pulseWidth)" line256="    }" line257="    // //% blockId=servo360_run_with_duration" line258="    // //% block=&quot;run 360° servo %pin  %speed %direction for %duration s&quot;" line259="    // //% expandableArgumentMode=&quot;enabled&quot;" line260="    // //% speed.min=0 speed.max=100 speed.defl=50" line261="    // //% duration.min=0 duration.max=100 duration.defl=1" line262="" line263="    // //% group=&quot;Servo Motor&quot; weight=4" line264="    // export function runServo360ForDuration(pin: ServoPin, speed: number, direction: RotationDirection, duration: number): void {" line265="    //     // 启动舵机" line266="    //     runServo360(pin, speed, direction)" line267="" line268="    //     // 等待指定时间" line269="    //     basic.pause(duration * 1000)" line270="" line271="    //     // 停止舵机" line272="    //     servo360Stop(pin)" line273="    // }" line274="" line275="    //% blockId=servo360Stop" line276="    //% block=&quot;stop 360° servo %pin&quot;" line277="    //% group=&quot;Servo Motor&quot; weight=3" line278="    export function servo360Stop(pin: ServoPin): void {" line279="        // 设置脉冲宽度为1.5ms停止" line280="        pins.servoSetPulse(pin, 1500)" line281="    }" line282="    " line283="    //#########################################################################" line284="    //##################################灯条#################################" line285="    //#########################################################################" line286="    // RGB LED控制类" line287="    class WS2812BStrip {" line288="        private buffer: Buffer" line289="        private pin: DigitalPin" line290="        private length: number" line291="        private brightness: number = 128" line292="" line293="        constructor(pin: DigitalPin, length: number) {" line294="            this.pin = pin" line295="            this.length = length" line296="            this.buffer = pins.createBuffer(length * 3)// 每个LED需要3个字节 (RGB)" line297="            pins.digitalWritePin(pin, 0)// 初始化引脚" line298="        }" line299="" line300="        // 设置单个LED的RGB颜色" line301="        setPixelColor(index: number, rgb: number): void {" line302="            if (index &lt; 0 || index &gt;= this.length) return" line303="" line304="            let r = (rgb &gt;&gt; 16) &amp; 0xFF" line305="            let g = (rgb &gt;&gt; 8) &amp; 0xFF" line306="            let b = rgb &amp; 0xFF" line307="" line308="            // 应用亮度" line309="            if (this.brightness &lt; 255) {" line310="                r = (r * this.brightness) &gt;&gt; 8" line311="                g = (g * this.brightness) &gt;&gt; 8" line312="                b = (b * this.brightness) &gt;&gt; 8" line313="            }" line314="" line315="            let offset = index * 3" line316="            // WS2812B使用GRB顺序" line317="            this.buffer[offset] = g     // G" line318="            this.buffer[offset + 1] = r // R" line319="            this.buffer[offset + 2] = b // B" line320="        }" line321="" line322="        // 显示所有LED" line323="        show(): void {" line324="            ws2812b.sendBuffer(this.buffer, this.pin)" line325="        }" line326="" line327="        // 清除所有LED" line328="        clear(): void {" line329="            for (let i = 0; i &lt; this.buffer.length; i++) {" line330="                this.buffer[i] = 0" line331="            }" line332="        }" line333="" line334="        // 设置亮度" line335="        setBrightness(brightness: number): void {" line336="            this.brightness = Math.min(255, Math.max(0, brightness))" line337="        }" line338="    }" line339="" line340="    // 全局变量存储当前灯条信息" line341="    let currentStrip: WS2812BStrip" line342="    let currentLEDCount: number = 8" line343="" line344="    //% blockId=ws2812b_init" line345="    //% block=&quot;init strip pin %pin with %ledCount LEDs&quot;" line346="    //% ledCount.min=1 ledCount.max=50 ledCount.defl=8" line347="    //% group=&quot;LED Strip&quot; weight=9" line348="    export function initStrip(pin: ServoPin, ledCount: number): void {" line349="        currentStrip = new WS2812BStrip(pin as number, ledCount)" line350="        currentLEDCount = ledCount" line351="    }" line352="" line353="    //% blockId=ws2812b_set_brightness" line354="    //% block=&quot;set brightness %brightness&quot;" line355="    //% brightness.min=0 brightness.max=255 brightness.defl=128" line356="    //% group=&quot;LED Strip&quot; weight=8" line357="    export function setBrightness(brightness: number): void {" line358="        if (currentStrip) {" line359="            currentStrip.setBrightness(brightness)" line360="        }" line361="    }" line362="" line363="    //% blockId=ws2812b_set_all" line364="    //% block=&quot;set all LEDs to %color&quot;" line365="    //% group=&quot;LED Strip&quot; weight=7" line366="    export function setAllColor(color: Colors): void {" line367="        if (currentStrip) {" line368="            for (let j = 0; j &lt; currentLEDCount; j++) {" line369="                currentStrip.setPixelColor(j, color)" line370="            }" line371="            currentStrip.show()" line372="        }" line373="    }" line374="" line375="    //% blockId=ws2812b_set_all_rgb" line376="    //% block=&quot;set all LEDs to R %red G %green B %blue&quot;" line377="    //% red.min=0 red.max=255 red.defl=255" line378="    //% green.min=0 green.max=255 green.defl=0" line379="    //% blue.min=0 blue.max=255 blue.defl=0" line380="    //% group=&quot;LED Strip&quot; weight=6" line381="    export function setAllRGB(red: number, green: number, blue: number): void {" line382="        if (currentStrip) {" line383="            let rgb = (red &lt;&lt; 16) | (green &lt;&lt; 8) | blue" line384="            for (let k = 0; k &lt; currentLEDCount; k++) {" line385="                currentStrip.setPixelColor(k, rgb)" line386="            }" line387="            currentStrip.show()" line388="        }" line389="    }" line390="" line391="    //% blockId=ws2812b_set_led" line392="    //% block=&quot;set LED %index to %color&quot;" line393="    //% index.min=0 index.defl=0" line394="    //% group=&quot;LED Strip&quot; weight=5" line395="    export function setLEDColor(index: number, color: Colors): void {" line396="        if (currentStrip &amp;&amp; index &gt;= 0 &amp;&amp; index &lt; currentLEDCount) {" line397="            currentStrip.setPixelColor(index, color)" line398="            currentStrip.show()" line399="        }" line400="    }" line401="" line402="    //% blockId=ws2812b_set_led_rgb" line403="    //% block=&quot;set LED %index to R %red G %green B %blue&quot;" line404="    //% index.min=0 index.defl=0" line405="    //% red.min=0 red.max=255 red.defl=255" line406="    //% green.min=0 green.max=255 green.defl=0" line407="    //% blue.min=0 blue.max=255 blue.defl=0" line408="    //% inlineInputMode=inline" line409="    //% group=&quot;LED Strip&quot; weight=4" line410="    export function setLEDRGB(index: number, red: number, green: number, blue: number): void {" line411="        if (currentStrip &amp;&amp; index &gt;= 0 &amp;&amp; index &lt; currentLEDCount) {" line412="            let rgb2 = (red &lt;&lt; 16) | (green &lt;&lt; 8) | blue" line413="            currentStrip.setPixelColor(index, rgb2)" line414="            currentStrip.show()" line415="        }" line416="    }" line417="" line418="    //% blockId=ws2812b_clear" line419="    //% block=&quot;clear all LEDs&quot;" line420="    //% group=&quot;LED Strip&quot; weight=3" line421="    export function clearAll(): void {" line422="        if (currentStrip) {" line423="            currentStrip.clear()" line424="            currentStrip.show()" line425="        }" line426="    }" line427="" line428="" line429="}" numlines="430"></mutation></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>